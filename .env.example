# Có thể để trống nếu nhập API key trên giao diện hoặc database có case khớp rất cao.
OPENAI_API_KEY=
GEMINI_API_KEY=

OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash

MAX_TOTAL_UPLOAD_MB=25
MAX_FILE_MB=8
MAX_PROMPT_CHARS=220000

# Đường dẫn SQLite. Để trống trong .env thì mặc định là data/phonebot_cases.db
PHONEBOT_DB_PATH=

# 0.58: đưa case cũ vào prompt tham khảo. 0.94: đủ mạnh để dùng cache, không gọi AI.
SIMILAR_CASE_MIN_SCORE=0.58
REUSE_CASE_MIN_SCORE=0.94
